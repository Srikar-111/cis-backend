generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("user") // admin, user
  createdAt    DateTime @default(now())
}

model ResourceRequest {
  id        Int      @id @default(autoincrement())
  type      String   // "VM" or "Storage"
  details   String   // JSON stringified configuration
  status    String   @default("Pending") // Pending, Provisioned, Failed
  createdAt DateTime @default(now())
}

model TestRun {
  id            Int      @id @default(autoincrement())
  name          String
  type          String   // "Unit" or "Integration"
  status        String   // "Pass" or "Fail"
  executionTime Int      // in milliseconds
  log           String?  // error logs or output
  timestamp     DateTime @default(now())
}
